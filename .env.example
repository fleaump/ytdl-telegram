TELEGRAM_BOT_TOKEN=
ADMIN_CHAT_ID=
ACCESS_PASSWORD=

# Для отправки файлов > 50МБ через локальный Telegram Bot API сервер:
# Получите TELEGRAM_API_ID и TELEGRAM_API_HASH на https://my.telegram.org
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# LOCAL_BOT_API_URL не нужно задавать вручную — он настроен в docker-compose
# Если запускаете без Docker, укажите: http://localhost:8081

# YouTube cookies — обход проверки "Sign in to confirm you're not a bot"
# Экспортируйте cookies из браузера (см. README.md) и положите файл cookies.txt в корень проекта
